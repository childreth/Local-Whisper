{
  "name": "local-whisper",
  "description": "Local speech-to-text transcription using Whisper",
  "author": "Chris Hildreth",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "vite build --watch & sleep 3 && electron . --inspect",
    "electron:build": "vite build && electron-builder && codesign --force --deep --sign - 'dist/mac-arm64/Local Whisper.app' && xattr -cr 'dist/mac-arm64/Local Whisper.app'"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "svelte": "^4.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.localwhisper.app",
    "productName": "Local Whisper",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.cjs",
      "icons/**/*"
    ],
    "mac": {
      "target": ["dmg"],
      "icon": "icons/icon.icns",
      "category": "public.app-category.utilities",
      "entitlementsInherit": "entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Local Whisper needs microphone access to transcribe speech.",
        "NSAppleEventsUsageDescription": "Local Whisper uses Apple Events to paste transcribed text into other apps."
      }
    }
  }
}
